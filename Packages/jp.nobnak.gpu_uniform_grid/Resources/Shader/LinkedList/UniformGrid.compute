#pragma kernel InitializeGrid

#include "../../../ShaderLibrary/LinkedList/UniformGrid.hlsl"

[numthreads(64,1,1)]
void InitializeGrid (uint3 id : SV_DispatchThreadID) {
	uint i = id.x;
	uint headLen = UniformGrid_cellHead_Len;
	if (i < headLen) {
		UniformGrid_SetHeadElementID(i, UniformGrid_InitValue);
		return;
	}
	uint j = i - headLen;
	if (j < UniformGrid_cellNext_Len)
		UniformGrid_SetNextElementID(j, UniformGrid_InitValue);
}
